---
layout: layouts/layout.njk
relative_path: '../..'
type: blogPost
ogType: article
---
{% include "translationWarning.njk" %}
<article>
    <h1>{{ title }}</h1>
    <div class="post-meta">
        <time datetime="{{ date.toISOString() }}">
            {{ i18n[locale].post.publishedOn }}: {{ date | postDate }}
        </time>
        {% if modified %}
        <span class="separator">•</span>
        <time datetime="{{ modified.toISOString() }}">
            {{ i18n[locale].post.updatedOn }}: {{ modified | postDate }}
        </time>
        {% endif %}
    </div>
    {{ content | safe }}
    {% if tags and tags.length %}
    <p class="post-tags-label">{{ i18n[locale].blog.tagged }}
      {% for tag in tags %}
      <a href="{% if locale == 'en' %}/posts/tag/{% else %}/{{ locale }}/posts/tag/{% endif %}{{ tag }}/" class="tag-pill">{{ tag }}</a>{% if not loop.last %} {% endif %}
      {% endfor %}
    </p>
    {% endif %}
</article>
