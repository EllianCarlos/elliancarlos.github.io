<script>
  (function() {
    const currentLang = '{{ locale }}' || 'en';
    const defaultLang = '{{ defaultLanguage }}';
    const supportedLangs = {{ languages | dump | safe }};
    const availableUrls = {{ collections.availableUrls | dump | safe }};
    const currentPath = window.location.pathname;

    // Never auto-redirect on error pages — the URL in the address bar may
    // already be for a missing translation (e.g. /pt/posts/xxx served via
    // /404.html), and redirecting would just prepend another /pt/ segment.
    if (document.getElementById('error-404')) return;

    // If the path already has a non-default language prefix, the user is
    // where they asked to be. Don't re-redirect.
    for (let i = 0; i < supportedLangs.length; i++) {
      const lang = supportedLangs[i];
      if (lang === defaultLang) continue;
      if (currentPath === '/' + lang || currentPath.indexOf('/' + lang + '/') === 0) return;
    }

    if (localStorage.getItem('preferredLanguage')) return;
    if (currentLang !== defaultLang) return;

    const browserLang = (navigator.language || '').split('-')[0];
    if (!browserLang || browserLang === defaultLang) return;
    if (supportedLangs.indexOf(browserLang) === -1) return;

    const targetUrl = '/' + browserLang + currentPath;
    const urlsForLang = availableUrls[browserLang] || [];
    if (urlsForLang.indexOf(targetUrl) === -1) return;

    window.location.replace(targetUrl);
  })();
</script>
